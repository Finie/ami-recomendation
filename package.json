  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --conditions=development src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "generate:courses": "tsx --conditions=development src/scripts/generate-courses.ts",
    "generate:users": "tsx --conditions=development src/scripts/generate-users.ts",
    "generate:surveys": "tsx --conditions=development src/scripts/generate-surveys.ts",
    "generate:usage": "tsx --conditions=development src/scripts/generate-usage-events.ts",
    "generate:data": "tsx --conditions=development src/scripts/generate-dataset.ts",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "prisma": "^7.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@google/genai": "^2.13.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
